---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: "MindMitra",
    description: "A bilingual, non-clinical mental health chatbot fine-tuned on culturally grounded synthetic therapy dialogues. Co-designed with Indian therapists and researchers, MindMitra offers a private, low-friction entry point to help students reduce stigma and build confidence to seek professional support.",
    tags: ["AI", "Mental Health", "NLP", "RCT"],
    link: "",
    github: "https://github.com/suhadewan/therabot-mvp",
  },
];
---

<BaseLayout title="Projects" activeNav="projects">
  <section class="section">
    <div class="container">
      <h1>Projects</h1>
      <p style="margin-bottom: 3rem;">A selection of things I've built and contributed to.</p>

      <div class="projects-grid">
        {projects.map((project) => (
          <div class="card project-card">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <div class="tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="project-links">
              {project.link && project.link !== "#" && (
                <a href={project.link} target="_blank" rel="noopener">Live demo</a>
              )}
              {project.github && project.github !== "" && (
                <a href={project.github} target="_blank" rel="noopener">GitHub</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.75rem;
  }

  .project-card h3 {
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .project-links {
    display: flex;
    gap: 1rem;
    margin-top: 1.25rem;
    font-size: 0.9rem;
  }
</style>
