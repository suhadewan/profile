---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" activeNav="contact">
  <section class="section">
    <div class="container contact-layout">
      <h1>Get in touch</h1>
      <p class="lead">
        Whether it's about AI, a collaboration, or just to say hi — I'd love to hear from you.
      </p>

      <div class="contact-links">
        <a href="mailto:suha.dewan@gmail.com" class="contact-item">
          <span class="contact-label">Email</span>
          <span class="contact-value">suha.dewan@gmail.com</span>
        </a>
        <a href="https://www.linkedin.com/in/suhadewan/" target="_blank" rel="noopener" class="contact-item">
          <span class="contact-label">LinkedIn</span>
          <span class="contact-value">linkedin.com/in/suhadewan</span>
        </a>
        <a href="https://github.com/suhadewan" target="_blank" rel="noopener" class="contact-item">
          <span class="contact-label">GitHub</span>
          <span class="contact-value">github.com/suhadewan</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-layout {
    max-width: 600px;
  }

  h1 {
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all var(--transition);
    color: var(--color-text);
  }

  .contact-item:hover {
    border-color: var(--color-accent);
    opacity: 1;
  }

  .contact-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .contact-value {
    font-size: 1.05rem;
  }
</style>
